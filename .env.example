# --------------------------------------------------
# SEO Audit Tool — Environment Variables
# --------------------------------------------------
# Production URL: https://seo-analyzer-nine-hazel.vercel.app/
# --------------------------------------------------
# Copy this file to .env.local and fill in the values.
#
# 1. AUTH_SECRET — random string used to encrypt session cookies
#    Generate with: openssl rand -base64 32
#
# 2. AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET
#    Get these from Google Cloud Console:
#    a) Go to https://console.cloud.google.com
#    b) Create or select a project
#    c) Enable "Google Search Console API"
#    d) Go to APIs & Services → Credentials → Create Credentials → OAuth client ID
#    e) Application type: Web application
#    f) Authorized redirect URIs:
#       - http://localhost:3000/api/auth/callback/google (local dev)
#       - https://seo-analyzer-nine-hazel.vercel.app/api/auth/callback/google (production)
#    g) Copy Client ID and Client Secret below
# --------------------------------------------------

AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 3. ANTHROPIC_API_KEY — for AI-powered content analysis
#    Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
